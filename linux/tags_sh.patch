+# determine CTAGS flavor in a robust way (prefer Universal when present)
+detect_ctags_mode()
+{
+    local prog="$1"
+    # get the first few lines of version output to avoid long multi-line matching issues
+    local ver
+    ver=$($prog --version 2>&1 | sed -n '1p' || true)
+
+    if printf "%s" "$ver" | grep -qi 'universal'; then
+        echo universal
+    elif printf "%s" "$ver" | grep -qi 'exuberant'; then
+        echo exuberant
+    else
+        echo other
+    fi
+}
